{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["ldproxy/renovate-config:xtraplatform", "ldproxy/renovate-config:maintenance2(4.7,4.6)"],
  "packageRules": [
    {
      "matchUpdateTypes": ["patch"],
      "matchCurrentVersion": "!/^0/",
      "automerge": true
    },
    {
      "matchUpdateTypes": ["digest"],
      "automerge": true
    },
    {
      "matchPackageNames": ["com.networknt:json-schema-validator"],
      "allowedVersions": "< 3.0.0"
    },
    {
      "groupName": "flatgeobuf",
      "matchPackageNames": ["/flatgeobuf/", "/flatbuffers/"]
    }
  ]
}
