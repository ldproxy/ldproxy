{{> header}}

<div>
  <h1>{{title}}</h1>
  <span>{{{description}}}</span>
  <br/>
  <br/>

  {{> pagination}}

  <div class="row my-3">
    <div class="col-md-10">
      <ul class="list-unstyled">
        {{#processList}}
          <li>
            <a href="processes/{{id}}">{{title}} ({{id}})</a>
            <br/>
            Version: {{version}}
            <br/>
            Job Control Options:
            <ul>
              {{#jobControlOptions}}
                <li>{{.}}</li>
              {{/jobControlOptions}}
              {{^jobControlOptions}}
                <li>{{none}}</li>
              {{/jobControlOptions}}
            </ul>
            <br/>
          </li>
        {{/processList}}
        {{^processList}}
          <li>{{none}}</li>
        {{/processList}}
      </ul>
    </div>
  </div>

  {{> pagination}}

</div>

{{> footer}}